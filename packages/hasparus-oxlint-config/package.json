{
  "name": "@hasparus/oxlint-config",
  "version": "0.1.1",
  "description": "my shared oxlint config",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./oxlint.config.ts",
      "default": "./oxlint.config.js"
    }
  },
  "files": [
    "oxlint.config.ts",
    "oxlint.config.js"
  ],
  "scripts": {
    "build": "tsc oxlint.config.ts --module esnext --moduleResolution bundler --target esnext --skipLibCheck",
    "lint": "oxlint",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "oxlint": "^1.70.0"
  },
  "dependencies": {
    "eslint-plugin-better-tailwindcss": "4.0.2",
    "eslint-plugin-perfectionist": "5.4.0",
    "eslint-plugin-sonarjs": "3.0.6"
  },
  "devDependencies": {
    "oxlint": "1.70.0",
    "typescript": "^5.9.3"
  }
}
