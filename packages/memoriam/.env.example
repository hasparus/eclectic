# Dev / single-tenant fallback site. When set, hooks.server.js auto-creates
# the site on startup (idempotent) and falls back to it when no custom
# domain / subdomain matches the request host.
MEMORIAM_DEFAULT_SITE_ID="default"

# Email of the user that owns the default site. Use this same address in
# the sign-in flow (magic link will be logged to stdout in dev).
MEMORIAM_DEFAULT_USER_EMAIL="admin@memoriam.local"

# Platform host suffix for subdomain-based site resolution.
# Requests to `<site_id>.memoriam.app` resolve to that site.
# MEMORIAM_HOST_SUFFIX="memoriam.app"

# Resend (transactional email). Leave RESEND_API_KEY unset in dev — the
# magic-link email body will be logged to stdout instead.
# RESEND_API_KEY="re_..."
# MEMORIAM_EMAIL_FROM="Memoriam <hello@yourdomain.com>"
# MEMORIAM_PRODUCT_NAME="Memoriam"
