		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25",
		"@types/pdfkit": "^0.17.6",
		"@types/qrcode": "^1.5.6",
		"@types/svg-to-pdfkit": "^0.1.4",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
